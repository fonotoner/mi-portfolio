---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: "en" } },
    { params: { lang: "eu" } },
  ];
}

import fs from "node:fs";
import path from "node:path";

import Layout from "../../layouts/Layout.astro";
import { getLocale, t } from "../../i18n/utils";
import "../../styles/dibu-svg-artista.css";

const currentLocale = getLocale(Astro.url);

/** Inline SVG so page CSS (SVG Artista) applies; <img> isolates the document from those rules. */
const dibuLightSvg = fs
  .readFileSync(path.join(process.cwd(), "public", "img", "yop-black.svg"), "utf-8")
  .replace('id="Capa_1"', 'id="dibu-svg-light"');
const dibuDarkSvg = fs
  .readFileSync(path.join(process.cwd(), "public", "img", "yop-white.svg"), "utf-8")
  .replace('id="Capa_1"', 'id="dibu-svg-dark"');
/** `icon` = basename in public/img/stack (without .svg) */
const stack: { label: string; icon: string }[] = [
  { label: "HTML5", icon: "html" },
  { label: "CSS3", icon: "css" },
  { label: "PHP", icon: "php" },
  { label: "MySQL", icon: "mysql" },
  { label: "JavaScript", icon: "js" },
  { label: "Node.js", icon: "nodejs" },
  { label: "Astro", icon: "astro" },
  { label: "React", icon: "react" },
  { label: "Tailwind", icon: "tailwind" },
  { label: "Vite", icon: "vite" },
  { label: "Git", icon: "git" },
  { label: "WordPress", icon: "wordpress" },
  { label: "Divi", icon: "divi" },
  { label: "Elementor", icon: "elementor" },
  { label: "WooCommerce", icon: "woocommerce" },
  { label: "SVG", icon: "svg" },
  { label: "Figma", icon: "figma" },
  { label: "Illustrator", icon: "illustrator" },
  { label: "Photoshop", icon: "photoshop" },
  { label: "InDesign", icon: "indesign" },
  { label: "After Effects", icon: "aftereffects" },
  { label: "Premiere Pro", icon: "premierepro" },
];
---

<Layout titulo={`${t("hero.greeting", currentLocale)} — Mi portfolio`}>
  <h1 class="text-7xl font-black animate-fade-down animate-duration-4000 animate-ease-in-out text-slate-900 dark:text-white">{t("hero.greeting", currentLocale)}</h1>
  <div class="flex flex-col items-center justify-center gap-6">
    <div class="flex gap-12 items-center">
      <div class="flex-col w-3/4">
        <p class="text-base text-balance text-slate-700 dark:text-slate-300 animate-fade-up mt-4">
          <span class="font-extralight italic">{t("hero.subtitle", currentLocale)}</span>
          <br /><br />{t("hero.description", currentLocale)}
        </p>
      </div>
      <span id="dibu" class="w-1/4 shrink-0 inline-block animate-pulse-fade-in [&_svg]:block [&_svg]:h-auto [&_svg]:w-full" role="img" aria-label="Fon">
        <span class="block dark:hidden" set:html={dibuLightSvg} />
        <span class="hidden dark:block" set:html={dibuDarkSvg} />
      </span>
    </div>
    <ul class="flex gap-3 flex-wrap justify-center">
      {
        stack.map(({ label, icon }, index) => (
          <li
            class="inline-flex items-center gap-2 bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-slate-200 px-4 py-2 rounded-full text-sm animate-fade-up hover:scale-120 hover:bg-slate-300 dark:hover:bg-slate-600 hover:text-slate-800 dark:hover:text-slate-300 hover:shadow-2xs transition-all ease-in-out"
            style={`animation-delay: ${index * 100}ms`}
          >
            <img
              src={`/img/stack/${icon}.svg`}
              alt=""
              width="16"
              height="16"
              class="h-[1em] w-[1em] shrink-0 object-contain opacity-90 dark:opacity-95"
              aria-hidden="true"
            />
            {label}
          </li>
        ))
      }
    </ul>
  </div>
</Layout>
