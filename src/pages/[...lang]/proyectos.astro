---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'en' } },
    { params: { lang: 'eu' } }
  ];
}

import Layout from '../../layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { getLocale, t } from '../../i18n/utils'

const currentLocale = getLocale(Astro.url)
const proyectos = await getCollection('proyectos')
---

<Layout titulo={`${t('projects.title', currentLocale)} — Mi portfolio`}>
  <h2 class="text-3xl font-bold mb-8 text-slate-900 dark:text-white">{t('projects.title', currentLocale)}</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {proyectos.map(proyecto => (
      <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 border border-slate-200 dark:border-slate-700">
        <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white">{proyecto.data.titulo}</h3>
        <p class="text-slate-600 dark:text-slate-400 mb-4">{proyecto.data.descripcion}</p>
        <div class="flex flex-wrap gap-2">
          {proyecto.data.tecnologias.map(tech => (
            <span class="bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-slate-300 px-3 py-1 rounded-full text-xs">{tech}</span>
          ))}
        </div>
        <p class="text-slate-500 dark:text-slate-400 text-sm mt-4">{proyecto.data.año}</p>
      </div>
    ))}
  </div>
</Layout>
