---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'en' } },
    { params: { lang: 'eu' } }
  ];
}

import Layout from '../../layouts/Layout.astro'
import { getPosts } from '../../lib/wpService'
import { getLocale, t } from '../../i18n/utils'

const currentLocale = getLocale(Astro.url)
const posts = await getPosts(10)
---

<Layout titulo={`${t('blog.title', currentLocale)} — Mi portfolio`}>
  <div class="max-w-4xl mx-auto">
    <h1 class="text-4xl font-bold mb-2 text-slate-900 dark:text-white">{t('blog.title', currentLocale)}</h1>
    <p class="text-slate-600 dark:text-slate-400 mb-8">{t('blog.latestArticles', currentLocale)}</p>
    
    {posts.length === 0 ? (
      <div class="bg-slate-100 dark:bg-slate-800 p-8 rounded-lg text-center">
        <p class="text-slate-600 dark:text-slate-400">
          {t('blog.emptyMessage', currentLocale)}
        </p>
      </div>
    ) : (
      <div class="grid gap-6">
        {posts.map((post) => {
          const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
          return (
          <article class="bg-white dark:bg-slate-800 p-6 rounded-lg border border-slate-200 dark:border-slate-700 hover:shadow-lg dark:hover:shadow-xl dark:hover:shadow-slate-900/50 transition-all">
            {featuredImage ? (
              <a href={currentLocale === 'es' ? `/blog/${post.slug}` : `/${currentLocale}/blog/${post.slug}`} class="block mb-4 overflow-hidden rounded-md aspect-video">
                <img 
                  src={featuredImage} 
                  alt={post.title.rendered} 
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                />
              </a>
            ) : null}
            <div class="flex items-start justify-between mb-3">
              <h2 class="text-2xl font-bold text-slate-900 dark:text-white">
                <a href={currentLocale === 'es' ? `/blog/${post.slug}` : `/${currentLocale}/blog/${post.slug}`} class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                  {post.title.rendered}
                </a>
              </h2>
            </div>
            
            <time class="text-sm text-slate-500 dark:text-slate-400 block mb-3">
              {(() => {
                const dateOptions: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'long', day: 'numeric' };
                const localeString = currentLocale === 'en' ? 'en-US' : currentLocale === 'eu' ? 'eu-ES' : 'es-ES';
                return new Date(post.date).toLocaleDateString(localeString, dateOptions);
              })()}
            </time>
            
            <div class="text-slate-600 dark:text-slate-300 mb-4 line-clamp-3">
              {post.excerpt.rendered.replace(/<[^>]*>/g, '').substring(0, 200)}...
            </div>
            
            <a
              href={currentLocale === 'es' ? `/blog/${post.slug}` : `/${currentLocale}/blog/${post.slug}`}
              class="inline-block px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded transition-colors"
            >
              {t('blog.readMore', currentLocale)}
            </a>
          </article>
        )})}
      </div>
    )}
  </div>
</Layout>
