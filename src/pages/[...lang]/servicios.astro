---

<Layout titulo={`${t('services.title', currentLocale)} — Mi portfolio`}>
  <h1 class="text-3xl font-bold mb-8 text-slate-900 dark:text-white">{t('services.title', currentLocale)}</h1>
  <div class="mb-8">
    <p class="block mb-2 text-slate-700 dark:text-slate-300 font-semibold">{t('services.filter', currentLocale)}</p>
    <div class="flex flex-wrap gap-3">
      {categorias.map(cat => (
        <label class="flex items-center gap-2 rounded-2xl border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-2 text-sm text-slate-700 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 hover:border-slate-400 dark:hover:border-slate-600 cursor-pointer group">
          <input type="checkbox" name="categoriaFiltro" value={cat.id} class="relative appearance-none w-3.5 h-3.5 border-2 border-slate-500 rounded-sm bg-white dark:bg-slate-800 checked:bg-slate-500 cursor-pointer peer" />
          <span class="text-xs group-hover:text-slate-900 dark:group-hover:text-slate-300">{cat.titulo}</span>
          <svg class="absolute w-4 h-4 mt-1 hidden peer-checked:block text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </label>
      ))}
    </div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {servicios.map(s => (
      <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 border border-slate-200 dark:border-slate-700" data-categorias={s.categorias.join(',')}>
        <h3 class="text-xl font-bold mb-2 text-slate-900 dark:text-white">{s.titulo}</h3>
        <p class="text-slate-600 dark:text-slate-400">{s.descripcion}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {s.categorias.map(catId => {
            const cat = categorias.find(c => c.id === catId);
            return <span class="bg-slate-200 dark:bg-slate-700 text-slate-900 dark:text-slate-300 px-2 py-1 rounded text-xs">{cat?.titulo}</span>;
          })}
        </div>
      </div>
    ))}
  </div>
  <script type="module">
    const checkboxes = Array.from(document.querySelectorAll('input[name="categoriaFiltro"]'));
    const cards = Array.from(document.querySelectorAll('[data-categorias]'));

    const filterServices = () => {
      const selected = checkboxes
        .filter(input => input.checked)
        .map(input => Number(input.value));

      cards.forEach(card => {
        const categorias = card.getAttribute('data-categorias').split(',').map(Number);
        const visible = selected.length === 0 || selected.some(id => categorias.includes(id));
        card.style.display = visible ? '' : 'none';
      });
    };

    checkboxes.forEach(input => input.addEventListener('change', filterServices));
  </script>
</Layout>
