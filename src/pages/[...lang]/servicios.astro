  { id: 3, titulo: "Modern Frontend", descripcion: "React, Astro and Tailwind", categorias: [5, 6, 7, 8, 9, 10] },
  { id: 4, titulo: "UX / UI", descripcion: "Sketch before designing", categorias: [16, 17, 18] },
  { id: 5, titulo: "Brand Identity", descripcion: "Brands, names, logos, manuals and more", categorias: [16, 17, 18, 19] },
