---
import Layout from '../layouts/Layout.astro'
import BotonContacto from '../components/BotonContacto.jsx'
---

<Layout titulo="Contacto — Mi portfolio">
  <div class="max-w-md mx-auto">
    <h2 class="text-3xl font-bold mb-8">Contacto</h2>
    <div class="flex flex-col gap-4">
      <input type="text" placeholder="Tu nombre" class="bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-400 outline-none focus:border-slate-500" />
      <input type="email" placeholder="Tu email" class="bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-400 outline-none focus:border-slate-500" />
      <BotonContacto client:load />
    </div>
  </div>
</Layout>