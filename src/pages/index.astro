---
import Layout from '../layouts/Layout.astro'
const stack = ["HTML5", "CSS3", "PHP", "MySQL", "JavaScript", "Node.js", "Astro", "React", "Tailwind", "Vite", "Git", "WordPress", "Divi", "Elementor", "WooCommerce", "Figma", "Illustrator", "Photoshop", "InDesign", "After Effects", "Premiere Pro"]
---

<Layout titulo="Inicio — Mi portfolio">
  <div class="flex flex-col items-center justify-center gap-6 mt-20">
    <h1 class="text-4xl font-bold">Hola, soy Fon</h1>
    <ul class="flex gap-3 flex-wrap justify-center">
      {stack.map(tech => (
        <li class="bg-slate-700 text-slate-200 px-4 py-2 rounded-full text-sm">{tech}</li>
      ))}
    </ul>
  </div>
</Layout>