---
import Layout from '../layouts/Layout.astro'
const stack = ["Astro", "React", "Tailwind", "Vite"]
---

<Layout titulo="Inicio — Mi portfolio">
  <div class="flex flex-col items-center justify-center gap-6 mt-20">
    <h1 class="text-4xl font-bold">Hola, soy Tu nombre</h1>
    <ul class="flex gap-3">
      {stack.map(tech => (
        <li class="bg-slate-700 text-slate-200 px-4 py-2 rounded-full text-sm">{tech}</li>
      ))}
    </ul>
  </div>
</Layout>