---
const buttonId = 'theme-toggle-button'
const iconId = 'theme-toggle-icon'
const darkIcon = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/></svg>`
const lightIcon = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.536l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.121-10.607a1 1 0 010 1.414l-.707.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.464 7.464a1 1 0 001.414-1.414l-.707-.707A1 1 0 003.757 6.757l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 100 2h1z" clip-rule="evenodd"/></svg>`
---
<button id={buttonId} class="p-2 rounded-lg bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 transition-all text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white" aria-label="Toggle dark mode" type="button">
  <span id={iconId} class="inline-flex items-center justify-center"></span>
</button>
<script define:vars={{ buttonId, iconId, darkIcon, lightIcon }}>
  (() => {
    const button = document.getElementById(buttonId)
    const icon = document.getElementById(iconId)
    const setIcon = (dark) => {
      if (!icon) return
      icon.innerHTML = dark ? darkIcon : lightIcon
    }

    const applyTheme = (isDark) => {
      document.documentElement.classList.toggle('dark', isDark)
      if (document.body) document.body.classList.toggle('dark', isDark)
      localStorage.setItem('theme', isDark ? 'dark' : 'light')
      setIcon(isDark)
    }

    const savedTheme = localStorage.getItem('theme')
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
    const initialDark = savedTheme ? savedTheme === 'dark' : prefersDark

    applyTheme(initialDark)

    if (button) {
      button.addEventListener('click', () => {
        applyTheme(!document.documentElement.classList.contains('dark'))
      })
    }
  })()
</script>
