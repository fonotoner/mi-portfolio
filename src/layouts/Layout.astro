---
import '../styles/global.css'
const { titulo } = Astro.props
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{titulo}</title>
  </head>
  <body class="min-h-screen bg-slate-900 text-white">
    <nav class="flex gap-6 p-6 border-b border-slate-700">
      <a href="/" class="text-slate-300 hover:text-white transition-colors">Inicio</a>
      <a href="/servicios" class="text-slate-300 hover:text-white transition-colors">Servicios</a>
      <a href="/contacto" class="text-slate-300 hover:text-white transition-colors">Contacto</a>
      <a href="/proyectos" class="text-slate-300 hover:text-white transition-colors">Proyectos</a>
    </nav>
    <main class="p-12">
      <slot />
    </main>
  </body>
</html>