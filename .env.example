# Environment Configuration
# Copy this file to .env.local and fill in the values below

# WordPress REST API Configuration (Optional)
# Set this to your WordPress site URL to enable fetching blog posts from WordPress
# If not set, the portfolio will use Markdown files in src/content/blog/
# Example: https://blog.tu-dominio.com
WORDPRESS_URL=

# Development Mode
# Set to true for verbose logging during development
# DEBUG=false

